#include <stdio.h>
void merge(int array[],int left,int mid,int right){
int i,j,k;
int temp[100];
 i=left;
 j= mid+1;
 k=0;
for(;i<=mid && j<=right;){
  if(array[i]<=array[j]){
 temp[k]=array[i];
 i++;
}
else{
temp[k]=array[j];
 j++; 
 }
 k++;
}
 for(;i<=mid;i++){
 temp[k]=array[i];
 k++;
}
for(;j<=right;j++){
temp[k]=array[j];
 k++;
} 
for(i=left,k=0;i<=right;i++,k++){
 array[i]=temp[k];
}
}
void mergeSort(int array[], int left, int right)
{
  if(left<right){
    int mid = (left+right) /2;
   mergeSort(array, left, mid);     
   mergeSort(array, mid+1,right);
   merge(array,left,mid,right);  
    }
}
int main()
{
int array[]={90,10,20,80,30,50};
int n=6;
 mergeSort(array,0,n-1);
    printf("Sorted array ");
  for(int i=0;i<n;i++){
     printf("%d    ", array[i]);
}
    return 0;
}
